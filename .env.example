# --- Obligatoire ---
# Code d'invitation que tes amis devront saisir pour créer un compte
INVITE_CODE=allez-les-bleus

# --- Recommandé : scores automatiques en temps réel ---
# Clé API gratuite : https://www.football-data.org/client/register (2 minutes)
# Sans clé, l'app fonctionne en mode manuel (l'admin saisit les scores)
# ou en mode démo (matchs simulés pour tester).
FOOTBALL_DATA_API_KEY=

# --- Optionnel ---
# Secret de session (généré automatiquement dans ./data si absent)
SESSION_SECRET=

# Chemin de la base SQLite (défaut: ./data/cdm.db)
# DATABASE_PATH=./data/cdm.db

# Cookies de session "Secure". Auto-détecté via HTTPS (x-forwarded-proto).
# Laisse vide si tu sers en http://ip:3000 sans TLS (sinon Safari refuse la session).
# Mets 1 seulement si tu es derrière HTTPS sans header de proxy.
# SECURE_COOKIES=

# Mode démo : crée des matchs fictifs qui se jouent en accéléré
# pour tester l'app sans clé API. Mettre à 1 pour activer.
DEMO_MODE=0
